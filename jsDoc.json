{
    "plugins": ["plugins/markdown"],
    "recurseDepth": 10,
    "opts": {
        "destination": "docs/api",
        "readme": "README.md",
        "recurse": true,
        "template": "node_modules/minami"
    },
    "source": {
        "include": ["src"],
        "includePattern": ".+\\.js(doc|x)?$",
        "excludePattern": "(^|\\/|\\\\)_"
    },
    "sourceType": "module",
    "tags": {
        "allowUnknownTags": true,
        "dictionaries": ["jsdoc","closure"]
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false
    }
}