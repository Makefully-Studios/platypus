{
    "name": "@makefully/platypus",
    "version": "4.1.3",
    "description": "2D tile-based HTML5 game engine with a component-based entity model",
    "license": "MIT",
    "contributors": [
        "Derek Detweiler <derek.detweiler@gmail.com> (https://github.com/probityrules)",
        "Todd Lewis <todd.lewis@gopherwoodstudios.com> (https://github.com/GopherwoodTodd)"
    ],
    "main": "lib/platypus.js",
    "exports": {
        ".": "./lib/platypus.js",
        "./platypus.css": "./lib/platypus.css",
        "./package.json": "./package.json"
    },
    "files": [
        "lib",
        "README.md",
        "CHANGELOG.md",
        "CONTRIBUTORS.md",
        "licenses.txt",
        "assets"
    ],
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Makefully-Studios/platypus.git"
    },
    "bugs": {
        "url": "https://github.com/Makefully-Studios/platypus/issues"
    },
    "homepage": "https://makefully-studios.github.io/platypus/",
    "keywords": [
        "platypus",
        "game-engine",
        "html5",
        "2d",
        "tiled",
        "pixi.js",
        "springroll"
    ],
    "scripts": {
        "start": "webpack serve --mode development",
        "build:release": "webpack --mode production",
        "build:debug": "webpack --mode development",
        "prepack": "npm run build:release",
        "pack:check": "npm pack --dry-run",
        "test:watch": "vitest",
        "test:run": "vitest run",
        "coverage": "vitest run --coverage",
        "assess:tiled": "node test/tiled/assess-coverage.mjs",
        "docs": "node scripts/build-docs.mjs",
        "docs:publish": "npm run docs && node scripts/publish-docs.mjs"
    },
    "dependencies": {
        "recycle": "github:gopherwood/recycle#master"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.1.7",
        "gh-pages": "^6.3.0",
        "jsdoc": "^3.6.11",
        "minami": "^1.2.3",
        "vitest": "^4.1.7",
        "webpack": "^5.99.9",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2"
    },
    "peerDependencies": {
        "@esotericsoftware/spine-pixi-v8": "^4.2.111",
        "@pixi/sound": "github:Makefully-Studios/sound#feature/media-file",
        "@tweenjs/tween.js": "^23.1.1",
        "pako": "^2.1.0",
        "pixi.js": "^8.1.5",
        "springroll": "^2.6.0"
    },
    "optionalDependencies": {
        "box2d3-wasm": "^4.2.0",
        "jsmediatags": "github:probityrules/jsmediatags",
        "poly-decomp": "^0.3.0"
    },
    "engines": {
        "node": ">=20"
    }
}
